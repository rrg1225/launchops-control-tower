{
  "name": "launchops-control-tower",
  "version": "1.0.0",
  "description": "Enterprise launch readiness control tower with portfolio risk scoring, RBAC approvals, audit trails, and operational metrics.",
  "type": "module",
  "license": "MIT",
  "author": "lixian",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "test": "node --test test/*.test.js",
    "build": "vite build",
    "start": "node server/index.js",
    "health": "node scripts/project-health.js"
  },
  "keywords": [
    "fullstack",
    "react",
    "express",
    "launch-management",
    "risk-scoring",
    "rbac",
    "audit-log"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.4.2"
  }
}
